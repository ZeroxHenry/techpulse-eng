---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Engineer Study — learning real tech from scratch.', lang = 'en' } = Astro.props;
const otherLang = lang === 'en' ? 'ko' : 'en';
const otherLangUrl = lang === 'en'
  ? Astro.url.pathname.replace(/^\//, '/ko/') || '/ko/'
  : Astro.url.pathname.replace(/^\/ko\//, '/') || '/';
const otherLangLabel = lang === 'en' ? 'KO' : 'EN';
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Henry" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>{title} | TechBlips</title>
  <script is:inline>
    if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Nav -->
  <nav class="sticky top-0 z-50 bg-white/80 dark:bg-gray-950/80 backdrop-blur-xl border-b border-gray-200 dark:border-gray-800">
    <div class="max-w-5xl mx-auto px-5 h-16 flex items-center justify-between">
      <a href={lang === 'ko' ? '/ko/' : '/'} class="text-xl font-extrabold tracking-tight hover:text-accent transition-colors">
        TechBlips
      </a>
      <div class="flex items-center gap-6">
        <div class="hidden sm:flex items-center gap-5 text-sm font-medium text-gray-600 dark:text-gray-400">
          <a href={lang === 'ko' ? '/ko/' : '/'} class="hover:text-accent transition-colors">
            {lang === 'ko' ? '홈' : 'Home'}
          </a>
          <a href={lang === 'ko' ? '/ko/study/' : '/study/'} class="hover:text-accent transition-colors">
            {lang === 'ko' ? '스터디' : 'Study'}
          </a>
          <a href={lang === 'ko' ? '/ko/about/' : '/about/'} class="hover:text-accent transition-colors">
            {lang === 'ko' ? '소개' : 'About'}
          </a>
        </div>
        <!-- Lang Toggle -->
        <a href={otherLangUrl} class="text-xs font-bold px-2.5 py-1 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:text-accent hover:bg-accent/10 transition-all">
          {otherLangLabel}
        </a>
        <!-- Theme Toggle -->
        <button id="theme-toggle" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" aria-label="Toggle theme">
          <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Main -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-200 dark:border-gray-800 py-8 text-center text-sm text-gray-500">
    <div class="max-w-5xl mx-auto px-5">
      &copy; {new Date().getFullYear()} TechBlips. Built by Henry.
    </div>
  </footer>

  <script is:inline>
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    });
  </script>
</body>
</html>
