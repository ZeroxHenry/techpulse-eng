---
import Base from '../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('ko-study');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.description} lang="ko">
  <article class="max-w-3xl mx-auto px-5 py-16">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4 text-sm text-gray-500">
        <time>{post.data.date.toLocaleDateString('ko-KR', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
        {post.data.series && <span class="text-accent font-medium">{post.data.series}</span>}
      </div>
      <h1 class="text-4xl font-black tracking-tight leading-tight mb-4">{post.data.title}</h1>
      {post.data.description && (
        <p class="text-lg text-gray-600 dark:text-gray-400">{post.data.description}</p>
      )}
      {post.data.tags && (
        <div class="flex gap-2 mt-4">
          {post.data.tags.map(tag => (
            <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider bg-accent/10 text-accent rounded-lg">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {post.data.youtube && (
      <div class="aspect-video rounded-2xl overflow-hidden mb-10 bg-gray-100 dark:bg-gray-900">
        <iframe
          src={`https://www.youtube.com/embed/${post.data.youtube}`}
          class="w-full h-full"
          allowfullscreen
          loading="lazy"
        />
      </div>
    )}

    <div class="prose max-w-none">
      <Content />
    </div>

    <div class="mt-12 p-5 rounded-2xl bg-accent/5 border border-gray-200 dark:border-gray-800 flex items-center gap-4">
      <div class="w-12 h-12 rounded-full bg-gradient-to-br from-accent to-blue-500 flex items-center justify-center text-white font-bold text-lg">H</div>
      <div>
        <div class="font-bold">Henry</div>
        <div class="text-sm text-gray-500">Building TechBlips</div>
      </div>
    </div>
  </article>
</Base>
