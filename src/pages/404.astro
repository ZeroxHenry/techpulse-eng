---
import Base from '../layouts/Base.astro';
---

<Base title="404">
  <section class="max-w-3xl mx-auto px-5 py-24 text-center">
    <div class="text-8xl font-black bg-gradient-to-r from-accent to-blue-500 bg-clip-text text-transparent mb-4">404</div>
    <h1 class="text-2xl font-bold mb-3">Page not found</h1>
    <p class="text-gray-500 mb-8">The page you're looking for doesn't exist.</p>
    <div class="flex gap-3 justify-center">
      <a href="/" class="px-6 py-3 bg-accent text-white font-semibold rounded-xl hover:bg-accent-hover transition-all">Go Home</a>
      <a href="/study/" class="px-6 py-3 border border-gray-200 dark:border-gray-700 font-semibold rounded-xl hover:border-accent transition-all">Study</a>
    </div>
  </section>
</Base>
