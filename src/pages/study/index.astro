---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('study'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="Study" lang="en">
  <section class="max-w-5xl mx-auto px-5 py-16">
    <h1 class="text-4xl font-black mb-3">Study Log</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-10">Real engineering topics studied from scratch, documented as we go.</p>

    {posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map(post => (
          <a href={`/study/${post.id}/`} class="group flex items-start gap-5 p-5 rounded-2xl border border-gray-200 dark:border-gray-800 hover:border-accent hover:shadow-lg hover:shadow-accent/5 transition-all hover:-translate-y-0.5">
            <div class="flex-1">
              <h2 class="text-lg font-bold group-hover:text-accent transition-colors">{post.data.title}</h2>
              {post.data.description && (
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{post.data.description}</p>
              )}
              <div class="flex items-center gap-3 mt-3 text-xs text-gray-500">
                <time>{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                {post.data.series && <span class="text-accent font-medium">{post.data.series}</span>}
                {post.data.youtube && <span class="text-red-500 font-medium">YouTube</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-500 text-lg">First study session coming soon.</p>
    )}
  </section>
</Base>
